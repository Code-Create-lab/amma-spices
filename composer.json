{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "fideloper/proxy": "^4.4",
        "guzzlehttp/guzzle": "^7.9",
        "kedniko/firebase-cloud-messaging-http-v1-php": "^0.0.2",
        "laravel/framework": "^v9.52.14",
        "laravel/passport": "^11.10",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^3.2",
        "league/flysystem-aws-s3-v3": "3.0.0",
        "livewire/livewire": "^3.0",
        "maatwebsite/excel": "^3.1",
        "nnjeim/world": "^1.1",
        "proengsoft/laravel-jsvalidation": "^4.9",
        "razorpay/razorpay": "^2.7",
        "spatie/laravel-sitemap": "^6.4",
        "spatie/laravel-sluggable": "^3.7",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^7.87",
        "twilio/sdk": "^6.26",
        "unicodeveloper/laravel-paystack": "^1.0",
        "web-token/jwt-framework": "^3.4",
        "yajra/laravel-datatables-oracle": "^10.11"
    },
    "require-dev": {
        "spatie/laravel-ignition": "^1.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^6.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "autoload": {

        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
		"files": [
            "app/Helpers/general.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }

    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
